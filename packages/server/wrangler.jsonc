{
  "name": "fragwait-server",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "durable_objects": {
    "bindings": [
      { "name": "MATCH", "class_name": "MatchDO" },
      { "name": "LOBBY", "class_name": "LobbyDO" },
      { "name": "CHESS_LOBBY", "class_name": "ChessLobbyDO" },
      { "name": "CHESS_MATCH", "class_name": "ChessMatchDO" },
      { "name": "BOMBER_LOBBY", "class_name": "BomberLobby2DO" },
      { "name": "BOMBER_MATCH", "class_name": "BomberMatch2DO" },
      { "name": "SNAKE_LOBBY", "class_name": "SnakeLobbyDO" },
      { "name": "SNAKE_MATCH", "class_name": "SnakeMatchDO" },
      { "name": "BLOCK_LOBBY", "class_name": "BlockLobbyDO" },
      { "name": "BLOCK_MATCH", "class_name": "BlockMatchDO" },
      { "name": "TANK_LOBBY", "class_name": "TankLobbyDO" },
      { "name": "TANK_MATCH", "class_name": "TankMatchDO" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["MatchDO", "LobbyDO"] },
    { "tag": "v2", "new_sqlite_classes": ["ChessLobbyDO", "ChessMatchDO"] },
    { "tag": "v3", "new_sqlite_classes": ["BomberLobbyDO", "BomberMatchDO"] },
    { "tag": "v4", "new_sqlite_classes": ["SnakeLobbyDO", "SnakeMatchDO"] },
    { "tag": "v5", "new_sqlite_classes": ["BlockLobbyDO", "BlockMatchDO"] },
    { "tag": "v6", "new_sqlite_classes": ["BomberLobby2DO", "BomberMatch2DO"] },
    { "tag": "v7", "new_sqlite_classes": ["TankLobbyDO", "TankMatchDO"] }
  ]
}
